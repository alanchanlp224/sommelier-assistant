{
  "name": "sommelier-assistant",
  "version": "1.0.3",
  "description": "Chrome extension that adds Vivino ratings to wine products on e-commerce sites",
  "repository": {
    "type": "git",
    "url": "https://github.com/alanchanlp224/sommelier-assistant.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "node scripts/bump-version.mjs && tsc && vite build",
    "preview": "vite preview",
    "package": "npm run build && node scripts/zip-dist.mjs"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "archiver": "^7.0.1"
  }
}
