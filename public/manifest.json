{
  "manifest_version": 3,
  "name": "Sommelier Assistant",
  "version": "1.0.5",
  "description": "Adds Vivino ratings to wine products on e-commerce websites",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "alarms",
    "downloads"
  ],
  "host_permissions": [
    "https://www.vivino.com/*",
    "https://api.github.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "css": []
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sommelier Assistant"
  }
}
